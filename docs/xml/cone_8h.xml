      <memberdef kind="function" id="cone_8h_1a5e37a9816d0935ddfa7ed9a28218bcff" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void nt_multiply</definition>
        <argsstring>(QOCOFloat *W, QOCOInt *Wsoc_idx, QOCOInt *soc_idx, QOCOFloat *x, QOCOFloat *z, QOCOInt l, QOCOInt m, QOCOInt nsoc, QOCOInt *q)</argsstring>
        <name>nt_multiply</name>
        <param>
          <type><ref refid="definitions_8h_1a4f04b37411a6fc01fed72b02f1364188" kindref="member">QOCOFloat</ref> *</type>
          <declname>W</declname>
        </param>
